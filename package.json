{
  "name": "wash",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "vitest run",
    "dev:admin": "npm run dev --prefix admin-app",
    "dev:all": "concurrently --names \"WASH,AGENT,ADMIN\" --prefix-colors \"cyan,magenta,yellow\" --kill-others-on-fail \"npm run dev\" \"npm run dev --prefix support-app\" \"npm run dev --prefix admin-app\"",
    "build": "vite build",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "check:env": "node scripts/check-env.js",
    "db:migrate": "node scripts/run-migrations.js",
    "db:migrate:bootstrap": "node scripts/run-migrations.js --bootstrap",
    "db:verify": "node scripts/verify-db.js",
    "setup": "npm run check:env && npm run db:migrate && npm run db:verify",
    "setup:buckets": "node scripts/create-verification-bucket.mjs",
    "android:sync": "npm run build && npx cap sync android",
    "android:open": "npx cap open android",
    "update": "powershell -ExecutionPolicy Bypass -File ./update.ps1"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/app": "^6.0.3",
    "@capacitor/camera": "^6.1.3",
    "@capacitor/core": "^6.2.1",
    "@capacitor/geolocation": "^6.1.1",
    "@capacitor/push-notifications": "^6.0.5",
    "@hookform/resolvers": "^5.2.2",
    "@mediapipe/tasks-vision": "^0.10.35",
    "@supabase/supabase-js": "^2.43.0",
    "@testing-library/dom": "^10.4.1",
    "emoji-picker-react": "^4.19.1",
    "framer-motion": "^12.38.0",
    "i18next": "^26.0.9",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.378.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.51.3",
    "react-i18next": "^17.0.6",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.23.0",
    "zod": "^3.23.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/leaflet": "^1.9.12",
    "@vitejs/plugin-basic-ssl": "^1.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "jsdom": "^29.1.1",
    "pg": "^8.12.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "vite": "^5.2.11",
    "vite-plugin-pwa": "^0.20.0",
    "vitest": "^4.1.7"
  }
}
