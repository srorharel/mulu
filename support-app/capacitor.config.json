{
  "appId": "com.sparklego.support",
  "appName": "Wash Support",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "allowNavigation": [
      "*.supabase.co",
      "*.googleapis.com",
      "*.gstatic.com"
    ]
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "launchShowDuration": 800,
      "backgroundColor": "#0f172a",
      "showSpinner": false
    }
  }
}
