# Copy to .env.local and fill in. These are PUBLIC values (the anon key is a
# publishable, RLS-protected key) used by the /auth/confirm landing page to call
# supabase.auth.verifyOtp / updateUser. Without them, /auth/confirm shows a
# configuration-error state (the rest of the marketing site works regardless).
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<publishable-anon-key>
