# ─── Supabase credentials ─────────────────────────────────────────────────────
# Find both values in: Supabase dashboard → Settings → API
# 1. Copy this file:   cp .env.example .env
# 2. Fill in all three variables below

# Project URL — Settings → API → Project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Anon / public key — Settings → API → Project API keys → anon public
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Database connection (migration scripts only — never sent to the browser) ──
# Find it in: Settings → Database → Connection string → URI
# Replace [YOUR-PASSWORD] with the database password you set when creating the project.
# Format:  postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres
